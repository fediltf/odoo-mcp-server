# ── MCP Server binding ────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8765

# Bearer token for SSE endpoint authentication.
# Leave empty to disable auth (not recommended in production).
MCP_API_KEY=change_me_to_a_strong_random_secret

# ── Odoo connection ───────────────────────────────────────────────────────────
# Use host.docker.internal if Odoo runs on the Docker host machine.
# Use the Docker service name (e.g. http://odoo:8069) if on the same network.
MCP_ODOO_URL=ttp://your-odoo-host
MCP_ODOO_DB=your_odoo_db_name
MCP_ODOO_USER=your_odoo_user
MCP_ODOO_PASSWORD=your_odoo_password

# ── Tool permissions ──────────────────────────────────────────────────────────
# Set to 1 to expose create / write / unlink tools. Default: 0 (disabled).
MCP_ALLOW_WRITE=0

# Set to 1 to expose execute_method tool. Default: 0 (disabled).
MCP_ALLOW_EXECUTE=0

# Comma-separated list of allowed Odoo models.
# Leave empty to allow all models.
# Example: res.partner,sale.order,account.move,product.product
MCP_ALLOWED_MODELS=

# ── Live config refresh ───────────────────────────────────────────────────────
# How often (seconds) to re-fetch allow_write/allow_execute/allowed_models
# from the Odoo mcp.config record. Default: 30.
MCP_CONFIG_TTL=30
